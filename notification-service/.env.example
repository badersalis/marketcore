# ── Message Queue ─────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@localhost:5672/

# ── Redis (ARQ job queue — db 4) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/4

# ── ARQ worker ────────────────────────────────────────────────────────────────
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=30
ARQ_KEEP_RESULT=3600
ARQ_MAX_TRIES=5

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Sender address shown in the "From" field.
# Option A (testing / free plan) — Resend's shared test domain, no verification needed:
#   EMAIL_FROM=Marketcore <onboarding@resend.dev>
# Option B (production) — use a domain you own and have verified in Resend:
#   EMAIL_FROM=Marketcore <noreply@yourdomain.com>
EMAIL_FROM=Marketcore <onboarding@resend.dev>
