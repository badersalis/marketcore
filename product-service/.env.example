# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/product_db

# ── Message Queue ─────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@localhost:5672/

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
# Same key as auth-service — used to verify tokens issued by auth-service
SECRET_KEY=secret-key-change-in-production
ALGORITHM=HS256
