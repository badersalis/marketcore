# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/market_user_db

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@rabbitmq:5672/

# ── JWT (must match auth-service) ─────────────────────────────────────────────
SECRET_KEY=secret-key-change-in-production
ALGORITHM=HS256

# ── Persona KYC ───────────────────────────────────────────────────────────────
# Obtain from https://withpersona.com → Dashboard → API keys (use sandbox key for local dev)
PERSONA_API_KEY=persona_sandbox_xxxxxxxxxxxx
# Template ID from Persona dashboard → Inquiry templates
PERSONA_INQUIRY_TYPE_ID=itmpl_xxxxxxxxxxxx
# Webhook signing secret from Persona dashboard → Webhooks
PERSONA_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── OTel ──────────────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=user-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://hyperdx:4318/v1/traces
